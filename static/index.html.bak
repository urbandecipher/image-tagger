const ZH_TO_EN={};
Object.entries(TAG_ZH).forEach(([en,zh])=>{ZH_TO_EN[zh]=en;});
function getZh(en){return TAG_ZH[en.toLowerCase()]||'';}
function resolveTag(s){const t=s.trim();return ZH_TO_EN[t]||t;}

