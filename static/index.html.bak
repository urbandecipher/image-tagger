<!DOCTYPE html>
<html lang="zh-TW" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ImageTag Studio</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ── Theme tokens ── */
[data-theme="dark"] {
  --bg:       #111113;
  --surface:  #18181b;
  --surface2: #1f1f23;
  --surface3: #28282e;
  --border:   #2e2e36;
  --border2:  #3a3a45;
  --accent:   #7c6aff;
  --accent-h: #9d8fff;
  --accent-s: rgba(124,106,255,0.15);
  --text:     #f0f0f4;
  --text2:    #a0a0b0;
  --text3:    #606070;
  --tag-bg:   #1e1e28;
  --tag-act:  #7c6aff;
  --sug-bg:   #1f1f27;
  --red:      #ff6b6b;
  --red-s:    rgba(255,107,107,0.12);
  --teal:     #2dd4bf;
  --shadow:   0 4px 24px rgba(0,0,0,0.4);
}
[data-theme="light"] {
  --bg:       #f4f4f7;
  --surface:  #ffffff;
  --surface2: #f0f0f4;
  --surface3: #e8e8ef;
  --border:   #dcdce6;
  --border2:  #c8c8d8;
  --accent:   #5b4de0;
  --accent-h: #7060f0;
  --accent-s: rgba(91,77,224,0.1);
  --text:     #1a1a2e;
  --text2:    #5a5a78;
  --text3:    #9090a8;
  --tag-bg:   #eeeef8;
  --tag-act:  #5b4de0;
  --sug-bg:   #ffffff;
  --red:      #e03535;
  --red-s:    rgba(224,53,53,0.08);
  --teal:     #0d9488;
  --shadow:   0 4px 24px rgba(0,0,0,0.10);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

body {
  font-family:'Inter',sans-serif;
  background:var(--bg);color:var(--text);
  display:grid;
  grid-template-columns:290px 1fr;
  grid-template-rows:52px 1fr;
  grid-template-areas:"header header" "sidebar main";
  height:100vh;overflow:hidden;
  transition:background 0.25s,color 0.25s;
}

/* ── Header ── */
header {
  grid-area:header;
  background:var(--surface);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 18px;gap:12px;
}
.logo {
  font-size:14px;font-weight:600;
  display:flex;align-items:center;gap:7px;
  color:var(--text);white-space:nowrap;
}
.logo-dot {
  width:7px;height:7px;border-radius:50%;
  background:var(--accent);box-shadow:0 0 8px var(--accent);
}
.header-sep{flex:1;}
.stat-pill {
  font-family:'JetBrains Mono',monospace;font-size:11px;
  color:var(--text2);background:var(--surface2);
  border:1px solid var(--border);border-radius:20px;
  padding:3px 10px;display:flex;align-items:center;gap:4px;white-space:nowrap;
}
.stat-pill b{color:var(--accent);font-weight:500;}

.icon-btn {
  width:32px;height:32px;border-radius:8px;border:1px solid var(--border);
  background:var(--surface2);color:var(--text2);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:15px;transition:all 0.15s;flex-shrink:0;
}
.icon-btn:hover{border-color:var(--accent);color:var(--accent);}

/* ── Sidebar ── */
.sidebar {
  grid-area:sidebar;background:var(--surface);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;
}
.sidebar-top{flex-shrink:0;}
.sidebar-scroll{flex:1;overflow-y:auto;}
.sidebar-scroll::-webkit-scrollbar{width:3px;}
.sidebar-scroll::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

.s-section{padding:12px 14px;border-bottom:1px solid var(--border);}
.s-label{font-size:10px;font-weight:600;letter-spacing:1px;color:var(--text3);
  text-transform:uppercase;margin-bottom:7px;}

/* inputs */
input[type="text"]{
  width:100%;background:var(--surface2);border:1px solid var(--border);
  border-radius:7px;color:var(--text);font-family:'Inter',sans-serif;
  font-size:13px;padding:7px 10px;outline:none;transition:border-color 0.2s;
}
input[type="text"]:focus{border-color:var(--accent);}
input[type="text"]::placeholder{color:var(--text3);}

/* buttons */
.btn {
  display:inline-flex;align-items:center;justify-content:center;gap:5px;
  font-family:'Inter',sans-serif;font-size:13px;font-weight:500;
  border:none;border-radius:7px;cursor:pointer;
  transition:all 0.15s;padding:7px 12px;white-space:nowrap;
}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover{background:var(--accent-h);}
.btn-ghost{background:var(--surface2);color:var(--text2);border:1px solid var(--border);}
.btn-ghost:hover{background:var(--surface3);color:var(--text);border-color:var(--border2);}
.btn-danger{background:var(--red-s);color:var(--red);border:1px solid transparent;}
.btn-danger:hover{border-color:var(--red);}
.btn:disabled{opacity:0.38;cursor:not-allowed;}
.btn-full{width:100%;}

/* range */
.range-row{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text2);}
input[type="range"]{flex:1;accent-color:var(--accent);height:3px;}
.range-val{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--accent);min-width:28px;}

/* progress */
.prog-wrap{margin-top:8px;display:none;}
.prog-wrap.show{display:block;}
.prog-track{height:3px;background:var(--surface3);border-radius:2px;overflow:hidden;margin-bottom:5px;}
.prog-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--teal));
  border-radius:2px;transition:width 0.4s;width:0%;}
.prog-text{font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--text3);
  display:flex;justify-content:space-between;}

/* ── Tag categories ── */
.sidebar-cat-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 14px 4px;border-bottom:1px solid var(--border);
  position:sticky;top:0;background:var(--surface);z-index:2;
}
.cat-ctrl-label{font-size:10px;font-weight:600;letter-spacing:1px;color:var(--text3);text-transform:uppercase;}
.cat-ctrl-btns{display:flex;gap:4px;}
.cat-ctrl-btn{
  font-size:10px;padding:2px 8px;border-radius:4px;
  border:1px solid var(--border);background:transparent;
  color:var(--text3);cursor:pointer;transition:all 0.15s;
  font-family:'Inter',sans-serif;
}
.cat-ctrl-btn:hover{border-color:var(--border2);color:var(--text);}
.cat-block{padding:8px 14px;border-bottom:1px solid var(--border);}
.cat-header{display:flex;align-items:center;gap:6px;cursor:pointer;
  user-select:none;padding:2px 0;border-radius:5px;}
.cat-header:hover .cat-title{color:var(--text);}
.cat-title{font-size:10px;font-weight:600;letter-spacing:0.8px;color:var(--text2);
  text-transform:uppercase;flex:1;transition:color 0.15s;}
.cat-count{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--text3);
  background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:1px 6px;}
.cat-arrow{font-size:9px;color:var(--text3);transition:transform 0.2s;}
.cat-arrow.open{transform:rotate(90deg);}
.cat-tags{display:flex;flex-wrap:wrap;gap:4px;margin-top:7px;
  overflow:hidden;transition:max-height 0.3s ease,margin-top 0.3s;max-height:2000px;}
.cat-tags.collapsed{max-height:0;margin-top:0;}

/* Tag list items (new list style) */
.tag-chip {
  display:flex;align-items:center;gap:0;
  padding:5px 10px 5px 0;cursor:pointer;
  border-radius:6px;transition:all 0.15s;
  position:relative;border-bottom:1px solid transparent;
}
.tag-chip:hover{background:var(--surface2);}
.tag-chip:hover .chip-bar{opacity:1;}
.tag-chip.active{background:var(--accent-s);}
.tag-chip.active .chip-en{color:var(--accent);}
.tag-chip.active .chip-bar{background:var(--accent);opacity:1;}

.chip-bar-wrap{
  width:6px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  margin-right:8px;margin-left:8px;
}
.chip-bar{
  width:4px;border-radius:2px;
  background:var(--accent);opacity:0.5;
  transition:all 0.2s;flex-shrink:0;
}
.chip-bar-full{
  height:3px;border-radius:2px;
  background:var(--accent);opacity:0.45;
  position:absolute;left:0;top:50%;transform:translateY(-50%);
  pointer-events:none;transition:width 0.3s ease;
}
.chip-en{
  font-family:'JetBrains Mono',monospace;font-size:11px;
  font-weight:500;color:var(--text2);flex:1;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  transition:color 0.15s;
}
.chip-zh{font-size:10px;color:var(--text3);flex-shrink:0;margin-right:8px;}
.chip-n{
  font-family:'JetBrains Mono',monospace;font-size:10px;
  color:var(--text3);flex-shrink:0;min-width:28px;text-align:right;
}

/* ── Main ── */
main{grid-area:main;display:flex;flex-direction:column;overflow:hidden;}

.toolbar{
  padding:8px 14px;background:var(--surface);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:8px;
}
.search-wrap{flex:1;position:relative;}
.search-icon{position:absolute;left:9px;top:50%;transform:translateY(-50%);
  color:var(--text3);pointer-events:none;font-size:12px;}
.search-wrap input{padding-left:30px;font-size:13px;}
.search-suggestions{
  position:absolute;top:calc(100% + 4px);left:0;right:0;
  background:var(--sug-bg);border:1px solid var(--border);
  border-radius:8px;z-index:60;max-height:220px;overflow-y:auto;
  display:none;box-shadow:var(--shadow);
}
.search-suggestions.show{display:block;}
.sug-item{padding:7px 11px;cursor:pointer;font-size:12px;
  display:flex;align-items:center;gap:8px;transition:background 0.1s;}
.sug-item:hover{background:var(--surface2);}
.sug-en{font-family:'JetBrains Mono',monospace;color:var(--text);font-size:11px;}
.sug-zh{color:var(--text2);font-size:11px;}
.sug-n{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);}

.fchip{
  font-size:12px;padding:5px 11px;border-radius:20px;
  border:1px solid var(--border);background:transparent;
  color:var(--text2);cursor:pointer;font-family:'Inter',sans-serif;
  transition:all 0.15s;white-space:nowrap;
}
.fchip.active{background:var(--accent);border-color:var(--accent);color:#fff;}
.fchip:hover:not(.active){border-color:var(--border2);color:var(--text);}

/* gallery */
.gallery{
  flex:1;overflow-y:auto;padding:14px;
  display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));
  gap:10px;align-content:start;
}
.gallery::-webkit-scrollbar{width:5px;}
.gallery::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}

.card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:10px;overflow:hidden;cursor:pointer;
  transition:all 0.18s;position:relative;
}
.card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:var(--shadow);}
.card-img{width:100%;aspect-ratio:1;object-fit:cover;display:block;background:var(--surface2);}
.card-body{padding:6px 7px;}
.card-tags{display:flex;flex-wrap:wrap;gap:3px;max-height:36px;overflow:hidden;}
.mini-tag{
  font-family:'JetBrains Mono',monospace;font-size:9px;
  background:var(--surface2);border-radius:4px;
  padding:2px 5px;color:var(--text3);white-space:nowrap;
}
.ubadge{
  position:absolute;top:5px;right:5px;font-size:9px;
  background:var(--red);color:#fff;border-radius:4px;
  padding:2px 5px;font-weight:600;
}

/* Select mode */
.card.selectable{cursor:pointer;}
.card.selected{border-color:var(--accent)!important;box-shadow:0 0 0 2px rgba(124,106,255,0.35);}
.card-check{
  position:absolute;top:6px;left:6px;
  width:20px;height:20px;border-radius:5px;
  border:2px solid rgba(255,255,255,0.7);
  background:rgba(0,0,0,0.3);
  display:none;align-items:center;justify-content:center;
  font-size:12px;color:#fff;transition:all 0.15s;
}
body.select-mode .card-check{display:flex;}
body.select-mode .card.selected .card-check{
  background:var(--accent);border-color:var(--accent);
}
body.select-mode .card:hover .card-check{border-color:#fff;}

/* Bulk action bar */
.bulk-bar{
  display:none;padding:8px 14px;
  background:var(--surface);border-bottom:1px solid var(--border);
  align-items:center;gap:10px;
  animation:fadeUp 0.2s ease;
}
body.select-mode .bulk-bar{display:flex;}
body.select-mode .toolbar{display:none;}
.bulk-count{font-size:13px;font-weight:500;color:var(--text);flex:1;}
.bulk-count span{color:var(--accent);font-weight:600;}
.move-input-wrap{display:flex;gap:6px;align-items:center;}
.move-input-wrap input{
  width:220px;font-size:12px;padding:6px 10px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:7px;color:var(--text);font-family:'Inter',sans-serif;outline:none;
}
.move-input-wrap input:focus{border-color:var(--accent);}
.move-input-wrap input::placeholder{color:var(--text3);}

/* Collection tabs */
.col-tabs-wrap{
  background:var(--surface);border-bottom:1px solid var(--border);
  display:flex;align-items:center;overflow-x:auto;
  scrollbar-width:none;gap:0;flex-shrink:0;
}
.col-tabs-wrap::-webkit-scrollbar{display:none;}
.col-tab{
  display:flex;align-items:center;gap:6px;
  padding:0 16px;height:38px;white-space:nowrap;
  font-size:13px;font-weight:500;color:var(--text2);
  cursor:pointer;border-bottom:2px solid transparent;
  transition:all 0.15s;flex-shrink:0;user-select:none;
}
.col-tab:hover{color:var(--text);background:var(--surface2);}
.col-tab.active{color:var(--accent);border-bottom-color:var(--accent);}
.col-tab .tab-count{
  font-family:'JetBrains Mono',monospace;font-size:10px;
  background:var(--surface2);border-radius:8px;
  padding:1px 6px;color:var(--text3);
}
.col-tab.active .tab-count{background:var(--accent-s);color:var(--accent);}
.col-tab-add{
  padding:0 12px;height:38px;display:flex;align-items:center;
  color:var(--text3);cursor:pointer;font-size:18px;
  transition:color 0.15s;flex-shrink:0;
}
.col-tab-add:hover{color:var(--accent);}

/* Collection manage modal */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.6);
  z-index:200;display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(4px);
}
.modal-overlay.open{display:flex;}
.modal{
  background:var(--surface);border:1px solid var(--border);
  border-radius:12px;padding:24px;width:360px;
  box-shadow:var(--shadow);animation:slideIn 0.2s ease;
}
.modal h3{font-size:16px;font-weight:600;margin-bottom:16px;}
.modal-row{display:flex;gap:8px;margin-bottom:12px;}
.modal-row input{flex:1;}
.col-list{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;max-height:240px;overflow-y:auto;}
.col-list-item{
  display:flex;align-items:center;gap:8px;
  padding:8px 10px;background:var(--surface2);
  border:1px solid var(--border);border-radius:7px;
}
.col-list-name{flex:1;font-size:13px;}
.col-list-count{font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace;}
.col-list-actions{display:flex;gap:4px;}
.col-act-btn{
  width:24px;height:24px;border-radius:5px;border:1px solid var(--border);
  background:transparent;color:var(--text3);cursor:pointer;
  font-size:12px;display:flex;align-items:center;justify-content:center;
  transition:all 0.15s;
}
.col-act-btn:hover{border-color:var(--border2);color:var(--text);}
.col-act-btn.del:hover{border-color:var(--red);color:var(--red);}

/* Bulk bar collection assign */
.assign-wrap{display:flex;gap:6px;align-items:center;}
.assign-wrap select{
  font-size:12px;padding:5px 8px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:7px;color:var(--text);font-family:'Inter',sans-serif;outline:none;
}

.pagination{
  padding:7px 14px;border-top:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  background:var(--surface);gap:8px;flex-wrap:wrap;
}
.page-info{font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace;white-space:nowrap;}
.page-btns{display:flex;gap:4px;align-items:center;flex-wrap:wrap;}
.page-num-btn{
  min-width:28px;height:28px;padding:0 6px;border-radius:6px;
  border:1px solid var(--border);background:transparent;
  color:var(--text2);cursor:pointer;font-family:'JetBrains Mono',monospace;
  font-size:11px;display:flex;align-items:center;justify-content:center;
  transition:all 0.15s;
}
.page-num-btn:hover{border-color:var(--border2);color:var(--text);}
.page-num-btn.active{background:var(--accent);border-color:var(--accent);color:#fff;}
.page-num-btn.ellipsis{border:none;cursor:default;color:var(--text3);}
.page-jump{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text3);}
.page-jump input{
  width:44px;padding:4px 6px;font-size:11px;text-align:center;
  font-family:'JetBrains Mono',monospace;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:6px;color:var(--text);outline:none;
}
.page-jump input:focus{border-color:var(--accent);}

/* ── Detail panel ── */
.det-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.5);
  z-index:100;display:none;backdrop-filter:blur(6px);
}
.det-overlay.open{display:flex;justify-content:flex-end;}
.det-panel{
  width:420px;background:var(--surface);border-left:1px solid var(--border);
  height:100%;display:flex;flex-direction:column;overflow:hidden;
  animation:slideIn 0.2s ease;box-shadow:-8px 0 32px rgba(0,0,0,0.2);
}
@keyframes slideIn{from{transform:translateX(24px);opacity:0;}to{transform:translateX(0);opacity:1;}}

.det-img-wrap{position:relative;background:var(--bg);flex-shrink:0;}
.det-img{width:100%;max-height:280px;object-fit:contain;display:block;}
.det-close{
  position:absolute;top:8px;right:8px;
  background:rgba(0,0,0,0.55);border:none;color:#fff;
  width:26px;height:26px;border-radius:50%;cursor:pointer;
  font-size:14px;display:flex;align-items:center;justify-content:center;
  transition:background 0.15s;
}
.det-close:hover{background:rgba(0,0,0,0.85);}
.det-nav{
  position:absolute;top:50%;transform:translateY(-50%);
  background:rgba(0,0,0,0.45);border:none;color:#fff;
  width:32px;height:48px;cursor:pointer;
  font-size:18px;display:flex;align-items:center;justify-content:center;
  transition:all 0.15s;border-radius:4px;
}
.det-nav:hover{background:rgba(0,0,0,0.8);}
.det-nav:disabled{opacity:0.2;cursor:default;}
.det-nav-prev{left:4px;}
.det-nav-next{right:4px;}
.det-nav-info{
  position:absolute;bottom:6px;left:50%;transform:translateX(-50%);
  font-family:'JetBrains Mono',monospace;font-size:10px;
  background:rgba(0,0,0,0.55);color:rgba(255,255,255,0.8);
  padding:2px 8px;border-radius:10px;pointer-events:none;
}

.det-body{flex:1;overflow-y:auto;padding:13px;}
.det-body::-webkit-scrollbar{width:4px;}
.det-body::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}

.det-path-row{
  display:flex;align-items:flex-start;gap:6px;margin-bottom:12px;
}
.det-path{
  flex:1;font-family:'JetBrains Mono',monospace;font-size:10px;
  color:var(--text2);word-break:break-all;line-height:1.6;
}
.reveal-btn{
  flex-shrink:0;width:26px;height:26px;border-radius:6px;
  border:1px solid var(--border);background:var(--surface2);
  color:var(--text2);cursor:pointer;font-size:13px;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.15s;margin-top:1px;
}
.reveal-btn:hover{border-color:var(--accent);color:var(--accent);}

.det-tags-wrap{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:11px;}
.edit-tag{
  font-family:'JetBrains Mono',monospace;font-size:10px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:6px;padding:4px 8px;color:var(--text);
  display:flex;align-items:center;gap:4px;line-height:1.2;
}
.edit-tag-en{font-size:10px;}
.edit-tag-zh{font-size:9px;color:var(--text2);margin-left:2px;}
.edit-tag .del{cursor:pointer;color:var(--text3);font-size:13px;
  line-height:1;transition:color 0.15s;margin-left:2px;}
.edit-tag .del:hover{color:var(--red);}

.add-row{display:flex;gap:7px;margin-bottom:11px;}
.add-row input{flex:1;}

.det-footer{
  padding:10px 13px;border-top:1px solid var(--border);
  display:flex;gap:7px;background:var(--surface);
}

/* empty */
.empty{
  grid-column:1/-1;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:60px 20px;color:var(--text3);gap:10px;font-size:14px;
}
.empty-icon{font-size:34px;opacity:0.35;}

/* toast */
.toast{
  position:fixed;bottom:20px;right:20px;background:var(--surface);
  border:1px solid var(--border);border-radius:8px;padding:10px 15px;
  font-size:13px;color:var(--text);z-index:999;
  animation:fadeUp 0.3s ease;max-width:300px;box-shadow:var(--shadow);
}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* loading */
#lov{position:fixed;inset:0;background:var(--bg);display:flex;
  flex-direction:column;align-items:center;justify-content:center;z-index:200;gap:14px;transition:opacity 0.4s;}
#lov.hidden{opacity:0;pointer-events:none;}
.spinner{width:32px;height:32px;border:2px solid var(--border);border-top-color:var(--accent);
  border-radius:50%;animation:spin 0.8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

.s-hint{padding:16px;text-align:center;color:var(--text3);font-size:12px;}

/* ── Trash Bin ── */
.trash-fab{
  position:fixed;bottom:28px;right:28px;z-index:90;
  width:52px;height:52px;border-radius:50%;
  background:var(--surface3);border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:22px;cursor:pointer;
  box-shadow:0 4px 20px rgba(0,0,0,0.4);
  transition:all 0.2s;user-select:none;
}
.trash-fab:hover{border-color:var(--red);transform:scale(1.08);}
.trash-fab.drag-over{
  background:var(--red-s);border-color:var(--red);
  transform:scale(1.18);box-shadow:0 6px 28px rgba(255,107,107,0.4);
}
.trash-fab .trash-count{
  position:absolute;top:-4px;right:-4px;
  min-width:18px;height:18px;border-radius:9px;
  background:var(--red);color:#fff;
  font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;
  display:flex;align-items:center;justify-content:center;
  padding:0 4px;border:2px solid var(--bg);
  display:none;
}
.trash-fab.has-items .trash-count{display:flex;}

/* Trash panel */
.trash-panel-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.6);
  z-index:200;display:none;align-items:flex-end;justify-content:flex-end;
  padding:0;
}
.trash-panel-overlay.open{display:flex;}
.trash-panel{
  width:380px;height:100vh;
  background:var(--surface);border-left:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;
  animation:slideIn 0.22s ease;box-shadow:-8px 0 32px rgba(0,0,0,0.3);
}
.trash-panel-header{
  padding:16px 18px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;flex-shrink:0;
}
.trash-panel-header h3{font-size:15px;font-weight:600;flex:1;}
.trash-panel-list{flex:1;overflow-y:auto;padding:10px;}
.trash-panel-list::-webkit-scrollbar{width:4px;}
.trash-panel-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.trash-item{
  display:flex;align-items:center;gap:10px;
  padding:7px 8px;border-radius:8px;
  background:var(--surface2);border:1px solid var(--border);
  margin-bottom:6px;transition:border-color 0.15s;
}
.trash-item:hover{border-color:var(--border2);}
.trash-item-thumb{
  width:52px;height:52px;border-radius:6px;
  object-fit:cover;flex-shrink:0;background:var(--surface3);
}
.trash-item-info{flex:1;min-width:0;}
.trash-item-name{
  font-family:'JetBrains Mono',monospace;font-size:10px;
  color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
  margin-bottom:3px;
}
.trash-item-tags{font-size:10px;color:var(--text3);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.trash-item-remove{
  width:24px;height:24px;border-radius:5px;flex-shrink:0;
  border:1px solid var(--border);background:transparent;
  color:var(--text3);cursor:pointer;font-size:13px;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.15s;
}
.trash-item-remove:hover{border-color:var(--red);color:var(--red);}
.trash-empty{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:40px 20px;color:var(--text3);gap:10px;font-size:13px;
}
.trash-empty-icon{font-size:36px;opacity:0.3;}
.trash-panel-footer{
  padding:12px 16px;border-top:1px solid var(--border);
  display:flex;gap:8px;flex-shrink:0;background:var(--surface2);
}

/* drag ghost */
.dragging{opacity:0.5;outline:2px dashed var(--accent);}

/* ── Scan History ── */
.history-modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.6);
  z-index:200;display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(4px);
}
.history-modal-overlay.open{display:flex;}
.history-modal{
  width:min(90vw,580px);max-height:80vh;
  background:var(--surface);border:1px solid var(--border);
  border-radius:12px;display:flex;flex-direction:column;
  overflow:hidden;box-shadow:var(--shadow);animation:slideIn 0.2s ease;
}
.history-modal-header{
  display:flex;align-items:center;padding:16px 18px;
  border-bottom:1px solid var(--border);flex-shrink:0;
}
.history-modal-header h3{font-size:15px;font-weight:600;flex:1;}
.history-list{flex:1;overflow-y:auto;padding:8px;}
.history-list::-webkit-scrollbar{width:4px;}
.history-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.history-item{
  display:flex;align-items:flex-start;gap:10px;
  padding:10px 12px;border-radius:8px;
  border:1px solid var(--border);background:var(--surface2);
  margin-bottom:6px;transition:border-color 0.15s;
}
.history-item:hover{border-color:var(--border2);}
.history-item-main{flex:1;min-width:0;}
.history-folder{
  font-family:'JetBrains Mono',monospace;font-size:11px;
  color:var(--text);word-break:break-all;line-height:1.5;
  margin-bottom:4px;
}
.history-meta{display:flex;gap:10px;flex-wrap:wrap;}
.history-badge{
  font-size:10px;color:var(--text3);
  display:flex;align-items:center;gap:3px;
}
.history-badge b{color:var(--accent2);}
.history-actions{display:flex;gap:4px;flex-shrink:0;margin-top:1px;}
.h-btn{
  width:26px;height:26px;border-radius:6px;
  border:1px solid var(--border);background:transparent;
  color:var(--text3);cursor:pointer;font-size:12px;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.15s;
}
.h-btn:hover{border-color:var(--border2);color:var(--text);}
.h-btn.del:hover{border-color:var(--red);color:var(--red);}
.history-empty{
  padding:32px;text-align:center;
  color:var(--text3);font-size:13px;
}

/* ── Analytics Panel ── */
.analytics-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.75);
  z-index:300;display:none;align-items:center;justify-content:center;
  backdrop-filter:blur(8px);
}
.analytics-overlay.open{display:flex;}
.analytics-panel{
  width:min(92vw,1100px);height:min(88vh,760px);
  background:var(--surface);border:1px solid var(--border);
  border-radius:16px;display:flex;flex-direction:column;
  overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,0.5);
  animation:slideIn 0.25s ease;
}
.analytics-header{
  display:flex;align-items:center;padding:16px 20px;
  border-bottom:1px solid var(--border);flex-shrink:0;gap:12px;
}
.analytics-header h2{font-size:16px;font-weight:600;flex:1;}
.analytics-header p{font-size:12px;color:var(--text3);}
.analytics-body{
  flex:1;display:flex;overflow:hidden;
}
.chart-area{
  flex:1;display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
.chart-area svg{max-width:100%;max-height:100%;}
.tag-detail-panel{
  width:280px;border-left:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;flex-shrink:0;
}
.tag-detail-header{
  padding:14px 16px 10px;border-bottom:1px solid var(--border);flex-shrink:0;
}
.tag-detail-title{font-size:13px;font-weight:600;margin-bottom:2px;}
.tag-detail-sub{font-size:11px;color:var(--text3);}
.tag-detail-list{flex:1;overflow-y:auto;padding:8px;}
.tag-detail-list::-webkit-scrollbar{width:4px;}
.tag-detail-list::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.tag-item{
  display:flex;align-items:center;gap:8px;
  padding:6px 8px;border-radius:6px;cursor:pointer;
  transition:background 0.15s;margin-bottom:2px;
}
.tag-item:hover{background:var(--surface2);}
.tag-item.selected{background:var(--accent-s);color:var(--accent);}
.tag-item-bar{
  height:4px;border-radius:2px;flex-shrink:0;
  background:var(--accent);opacity:0.6;
}
.tag-item-name{font-family:'JetBrains Mono',monospace;font-size:11px;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.tag-item-zh{font-size:10px;color:var(--text3);flex-shrink:0;}
.tag-item-count{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--text3);flex-shrink:0;}
.analytics-footer{
  padding:10px 20px;border-top:1px solid var(--border);
  display:flex;align-items:center;gap:10px;flex-shrink:0;
  background:var(--surface2);
}
.selected-tags-wrap{
  flex:1;display:flex;flex-wrap:wrap;gap:5px;align-items:center;
  font-size:12px;color:var(--text3);
}
.sel-tag-chip{
  font-family:'JetBrains Mono',monospace;font-size:10px;
  background:var(--accent-s);border:1px solid var(--accent);
  color:var(--accent);border-radius:4px;padding:2px 8px;
  display:flex;align-items:center;gap:4px;
}
.sel-tag-chip .x{cursor:pointer;opacity:0.7;}
.sel-tag-chip .x:hover{opacity:1;}
/* tooltip */
.chart-tooltip{
  position:fixed;pointer-events:none;
  background:var(--surface3);border:1px solid var(--border);
  border-radius:7px;padding:8px 12px;font-size:12px;
  color:var(--text);z-index:400;white-space:nowrap;
  box-shadow:var(--shadow);display:none;
}
</style>
</head>
<body>

<div id="lov"><div class="spinner"></div><div style="font-size:13px;color:var(--text3)" data-i18n="loading">載入中...</div></div>

<header>
  <div class="logo"><div class="logo-dot"></div>ImageTag Studio</div>
  <div class="header-sep"></div>
  <div class="stat-pill" id="pill-total">總計 <b id="stat-total">0</b> 張</div>
  <div class="stat-pill" id="pill-untagged">未標記 <b id="stat-untagged">0</b> 張</div>
  <div class="icon-btn" onclick="openAnalytics()" title="Tag 分析圖表" style="font-size:13px;">📊</div>
  <div class="icon-btn" onclick="toggleTheme()" id="theme-btn" title="切換亮/暗">🌙</div>
  <div class="icon-btn" onclick="toggleLang()" id="lang-btn" title="切換語言" style="font-size:12px;font-weight:600;">EN</div>
</header>

<div class="sidebar">
  <div class="sidebar-top">
    <div class="s-section">
      <div class="s-label" data-i18n="folder-label">圖片資料夾</div>
      <input type="text" id="folder-input" placeholder="C:\Users\...\images" style="margin-bottom:7px">
      <div style="display:flex;gap:6px;">
        <button class="btn btn-ghost" style="flex:1" onclick="scanFolder()">
          <span>🔍</span><span data-i18n="scan-btn">掃描資料夾</span>
        </button>
        <button class="icon-btn" onclick="openHistoryModal()" title="匯入歷史" style="flex-shrink:0">🗂</button>
      </div>
    </div>
    <div class="s-section">
      <div class="s-label" data-i18n="tag-settings-label">自動打標設定</div>
      <div class="range-row" style="margin-bottom:9px">
        <span data-i18n="threshold-label">信心閾值</span>
        <input type="range" id="threshold" min="0.1" max="0.9" step="0.05" value="0.35"
               oninput="document.getElementById('thresh-val').textContent=parseFloat(this.value).toFixed(2)">
        <span class="range-val" id="thresh-val">0.35</span>
      </div>
      <button class="btn btn-primary btn-full" id="tag-btn" onclick="startTagging()">
        <span>⚡</span><span data-i18n="start-tag-btn">開始打標</span>
      </button>
      <div class="prog-wrap" id="prog-wrap">
        <div class="prog-track"><div class="prog-fill" id="prog-fill"></div></div>
        <div class="prog-text"><span id="prog-cur">—</span><span id="prog-pct">0%</span></div>
      </div>
    </div>
  </div>
  <div class="sidebar-cat-header">
    <span class="cat-ctrl-label" data-i18n="tags-section">Tags</span>
    <div class="cat-ctrl-btns">
      <button class="cat-ctrl-btn" onclick="collapseAllCats()" data-i18n="collapse-all">全部收合</button>
      <button class="cat-ctrl-btn" onclick="expandAllCats()" data-i18n="expand-all">全部展開</button>
    </div>
  </div>
  <div class="sidebar-scroll" id="tag-categories">
    <div class="s-hint" data-i18n="scan-hint">掃描後顯示 Tags</div>
  </div>
</div>

<main>
  <!-- Normal toolbar -->
  <div class="toolbar">
    <div class="search-wrap">
      <span class="search-icon">⌕</span>
      <input type="text" id="search-input" placeholder="搜索 tag 或輸入中文，逗號分隔...">
      <div class="search-suggestions" id="sug-box"></div>
    </div>
    <button class="fchip" id="untagged-filter" onclick="toggleUntagged()" data-i18n="untagged-filter">未標記</button>
    <button class="btn btn-ghost" onclick="refreshGallery()" data-i18n="refresh-btn">重整</button>
    <button class="fchip" id="select-mode-btn" onclick="toggleSelectMode()" data-i18n="select-mode">選取</button>
  </div>

  <!-- Bulk action bar (visible in select mode) -->
  <div class="bulk-bar">
    <div class="bulk-count">已選取 <span id="sel-count">0</span> 張</div>
    <button class="cat-ctrl-btn" onclick="selectAll()" data-i18n="select-all">全選</button>
    <button class="cat-ctrl-btn" onclick="clearSelection()" data-i18n="clear-sel">取消全選</button>
    <div class="assign-wrap">
      <select id="assign-col-select">
        <option value="">移入集合...</option>
      </select>
      <button class="btn btn-ghost" style="padding:6px 10px;font-size:12px" onclick="bulkAssignCollection()">指派</button>
    </div>
    <div class="move-input-wrap">
      <input type="text" id="move-target" placeholder="目標資料夾路徑...">
      <button class="btn btn-ghost" style="padding:6px 10px;font-size:12px" onclick="bulkMove()" data-i18n="move-btn">移動</button>
    </div>
    <button class="btn btn-danger" style="padding:6px 12px;font-size:12px" onclick="bulkDelete()" data-i18n="delete-btn-bulk">刪除檔案</button>
    <button class="cat-ctrl-btn" onclick="toggleSelectMode()" data-i18n="cancel-sel">取消</button>
  </div>

  <!-- Collection tabs -->
  <div class="col-tabs-wrap" id="col-tabs"></div>

  <div class="gallery" id="gallery">
    <div class="empty"><div class="empty-icon">🖼</div><div data-i18n="empty-hint">輸入資料夾路徑並掃描以開始</div></div>
  </div>

  <div class="pagination">
    <div class="page-info" id="page-info">— / —</div>
    <div class="page-btns" id="page-btns"></div>
    <div class="page-jump">
      <span data-i18n="goto-page">跳至</span>
      <input type="number" id="page-jump-input" min="1" value="1">
      <button class="cat-ctrl-btn" onclick="jumpToPage()" data-i18n="goto-btn">GO</button>
    </div>
  </div>
</main>

<!-- Detail -->
<div class="det-overlay" id="det-overlay" onclick="closeDetail(event)">
  <div class="det-panel" onclick="event.stopPropagation()">
    <div class="det-img-wrap">
      <img class="det-img" id="det-img" src="" alt="">
      <button class="det-close" onclick="closeDetail()">✕</button>
      <button class="det-nav det-nav-prev" id="det-prev" onclick="navDetail(-1)" title="上一張 ←">‹</button>
      <button class="det-nav det-nav-next" id="det-next" onclick="navDetail(1)" title="下一張 →">›</button>
      <div class="det-nav-info" id="det-nav-info"></div>
    </div>
    <div class="det-body">
      <div class="det-path-row">
        <div class="det-path" id="det-path"></div>
        <button class="reveal-btn" onclick="revealInExplorer()" title="在檔案總管中開啟">📂</button>
      </div>
      <div class="s-label" style="margin-bottom:8px" data-i18n="tags-label">Tags</div>
      <div class="det-tags-wrap" id="det-tags"></div>
      <div class="add-row">
        <input type="text" id="new-tag-input" data-i18n-ph="add-tag-ph" placeholder="新增 tag...">
        <button class="btn btn-ghost" onclick="addTag()">＋</button>
      </div>
    </div>
    <div class="det-footer">
      <button class="btn btn-primary" style="flex:1" onclick="saveTags()">
        <span>💾</span><span data-i18n="save-btn">儲存</span>
      </button>
      <button class="btn btn-danger" onclick="deleteImagePermanent()" title="永久刪除檔案">🗑</button>
    </div>
  </div>
</div>

<!-- Trash Bin FAB -->
<div class="trash-fab" id="trash-fab"
  ondragover="onTrashDragOver(event)"
  ondragleave="onTrashDragLeave(event)"
  ondrop="onTrashDrop(event)"
  onclick="openTrashPanel()">
  🗑
  <div class="trash-count" id="trash-count">0</div>
</div>

<!-- Trash Panel -->
<div class="trash-panel-overlay" id="trash-overlay" onclick="closeTrashPanel(event)">
  <div class="trash-panel" onclick="event.stopPropagation()">
    <div class="trash-panel-header">
      <h3>🗑 待刪除清單</h3>
      <button class="icon-btn" onclick="closeTrashPanel()">✕</button>
    </div>
    <div class="trash-panel-list" id="trash-list"></div>
    <div class="trash-panel-footer">
      <button class="btn btn-ghost" style="flex:1;font-size:12px" onclick="clearTrash()">清空清單</button>
      <button class="btn btn-danger" style="flex:1;font-size:12px" onclick="confirmDeleteAll()">永久刪除全部</button>
    </div>
  </div>
</div>

<!-- Scan History Modal -->
<div class="history-modal-overlay" id="history-overlay" onclick="closeHistoryModal(event)">
  <div class="history-modal" onclick="event.stopPropagation()">
    <div class="history-modal-header">
      <h3>🗂 匯入歷史紀錄</h3>
      <button class="icon-btn" onclick="closeHistoryModal()" style="flex-shrink:0">✕</button>
    </div>
    <div class="history-list" id="history-list">
      <div class="history-empty">載入中...</div>
    </div>
  </div>
</div>

<!-- Analytics Panel -->
<div class="analytics-overlay" id="analytics-overlay" onclick="closeAnalytics(event)">
  <div class="analytics-panel" onclick="event.stopPropagation()">
    <div class="analytics-header">
      <div>
        <h2>📊 Tag 分析圖表</h2>
        <p>點擊色環選擇分類，點擊右側 tag 加入搜索條件</p>
      </div>
      <button class="icon-btn" onclick="closeAnalytics()" style="flex-shrink:0">✕</button>
    </div>
    <div class="analytics-body">
      <div class="chart-area" id="chart-area">
        <div style="color:var(--text3);font-size:13px">載入中...</div>
      </div>
      <div class="tag-detail-panel">
        <div class="tag-detail-header">
          <div class="tag-detail-title" id="detail-cat-title">選擇分類</div>
          <div class="tag-detail-sub" id="detail-cat-sub">點擊左側色環查看 tag</div>
        </div>
        <div class="tag-detail-list" id="tag-detail-list"></div>
      </div>
    </div>
    <div class="analytics-footer">
      <div class="selected-tags-wrap" id="sel-tags-wrap">
        <span id="sel-tags-hint">點擊 tag 加入搜索...</span>
      </div>
      <button class="btn btn-ghost" style="padding:6px 12px;font-size:12px" onclick="clearAnalyticsSel()">清除</button>
      <button class="btn btn-primary" style="padding:6px 14px;font-size:12px" onclick="applyAnalyticsSearch()">搜索圖片 →</button>
    </div>
  </div>
</div>
<div class="chart-tooltip" id="chart-tooltip"></div>

<!-- Collection manage modal -->
<div class="modal-overlay" id="col-modal" onclick="closeColModal(event)">
  <div class="modal" onclick="event.stopPropagation()">
    <h3>管理集合</h3>
    <div class="modal-row">
      <input type="text" id="new-col-input" placeholder="新集合名稱...">
      <button class="btn btn-primary" style="padding:7px 12px" onclick="addCollection()">新增</button>
    </div>
    <div class="col-list" id="col-list"></div>
    <button class="btn btn-ghost btn-full" onclick="closeColModal()">關閉</button>
  </div>
</div>

<script>
// ── Tag translations ───────────────────────────────────────────────────────────
const TAG_ZH = {
