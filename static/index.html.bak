let lang=localStorage.getItem('lang')||'zh';
function t(key,vars){
  let s=(I18N[lang]||I18N.zh)[key]||key;
  if(vars)Object.keys(vars).forEach(k=>{s=s.replaceAll('{'+k+'}',vars[k]);});
  return s;
}
function applyI18n(){
  document.querySelectorAll('[data-i18n]').forEach(el=>el.textContent=t(el.dataset.i18n));
  document.querySelectorAll('[data-i18n-ph]').forEach(el=>el.placeholder=t(el.dataset.i18nPh));
  document.getElementById('lang-btn').textContent=lang==='zh'?'EN':'中文';
  document.getElementById('search-input').placeholder=t('search-placeholder');
  refreshStats_ui();
}
function toggleLang(){lang=lang==='zh'?'en':'zh';localStorage.setItem('lang',lang);applyI18n();renderTagCategories(window._allTags||[]);}

// ── Theme ─────────────────────────────────────────────────────────────────────
let theme=localStorage.getItem('theme')||'dark';
function applyTheme(){
  document.documentElement.setAttribute('data-theme',theme);
  document.getElementById('theme-btn').textContent=theme==='dark'?'🌙':'☀️';
}
function toggleTheme(){theme=theme==='dark'?'light':'dark';localStorage.setItem('theme',theme);applyTheme();}
applyTheme();

// ── Tag Categories ────────────────────────────────────────────────────────────
const TAG_CATS=[
  {key:'cat-character',kw:['1girl','2girls','3girls','1boy','2boys','solo','multiple girls','multiple boys','crowd','chibi','robot','android','solo focus']},
  {key:'cat-hair',kw:['hair','twintails','ponytail','braid','bun','ahoge','bangs','blonde','black hair','brown hair','red hair','white hair','silver hair','blue hair','green hair','pink hair','purple hair','orange hair','grey hair','teal hair','multicolored hair','gradient hair']},
  {key:'cat-face',kw:['smile','grin','laugh','cry','tears','blush','frown','angry','sad','surprised','shocked','expressionless','eyes','mouth','lips','nose','looking at viewer','looking away','looking back','looking up','looking down','closed eyes','open mouth','closed mouth','parted lips','tongue','teeth','wink','heterochromia','red eyes','blue eyes','green eyes','brown eyes','purple eyes','grey eyes','yellow eyes','black eyes','pink eyes','aqua eyes','glowing eyes','earrings','portrait']},
  {key:'cat-clothing',kw:['dress','skirt','shirt','jacket','coat','uniform','suit','swimsuit','bikini','shorts','pants','jeans','leggings','stockings','thighhighs','socks','shoes','boots','heels','hat','cap','ribbon','bow','tie','scarf','gloves','necklace','bracelet','ring','jewelry','armor','weapon','sword','gun','mask','glasses','sunglasses','hairpin','kimono','yukata','maid','school uniform','sailor','apron','cloak','hoodie','sweater','sleeveless','bare shoulders','collar','choker','belt','lace','frills','lingerie','bra']},
  {key:'cat-pose',kw:['standing','sitting','lying','kneeling','running','walking','jumping','floating','crouching','leaning','arms up','hand on hip','crossed arms','v sign','peace sign','pointing','upper body','lower body','full body','close-up','cowboy shot','bust','from above','from below','from behind','from side','dutch angle','profile','head tilt']},
  {key:'cat-background',kw:['background','simple background','white background','black background','grey background','outdoors','indoors','sky','clouds','forest','trees','grass','flowers','garden','beach','ocean','sea','water','city','urban','street','building','room','bedroom','school','office','night','day','sunset','sunrise','rain','snow','fog','cherry blossom','space','stars','moon','sun','bokeh','blurry background','depth of field','scenery']},
  {key:'cat-style',kw:['realistic','anime','semi-realistic','3d','cg','sketch','lineart','watercolor','oil painting','digital art','masterpiece','best quality','high quality','ultra detailed','detailed','absurdres','highres','monochrome','greyscale','colorful','pastel','cinematic','dramatic lighting','soft lighting','backlighting','rim light','shadow']},
];
function categorizeTag(tag){
  const l=tag.toLowerCase();
  for(const cat of TAG_CATS){if(cat.kw.some(k=>l.includes(k)||k.includes(l)))return cat.key;}
  return 'cat-other';
}

// ── State ─────────────────────────────────────────────────────────────────────
let S={page:1,perPage:60,total:0,query:'',untaggedOnly:false,folder:'',
  detail:null,detailTags:[],progressTimer:null,catOpen:{},statTotal:0,statUntagged:0,
  selectMode:false,selected:new Set(),lastClickedIdx:-1,
  trashSet:new Set(),trashItems:{},
  // collection: null=all, -1=uncollected, N=collection id
  activeCollection:null,collections:[]};

async function api(method,path,body){
  const opts={method,headers:{'Content-Type':'application/json'}};
  if(body)opts.body=JSON.stringify(body);
  const r=await fetch(path,opts);
  if(!r.ok){const tx=await r.text();throw new Error(tx);}
  return r.json();
}

// ── Init ──────────────────────────────────────────────────────────────────────
async function init(){
  applyI18n();
  try{
    const cfg=await api('GET','/api/config');
    if(cfg.threshold){
      document.getElementById('threshold').value=cfg.threshold;
      document.getElementById('thresh-val').textContent=parseFloat(cfg.threshold).toFixed(2);
    }
    if(cfg.last_folder){
      S.folder=cfg.last_folder;
      document.getElementById('folder-input').value=cfg.last_folder;
      await loadCollections();
      await refreshGallery();await loadTagCategories();await refreshStats();
    } else {
      await loadCollections();
    }
  }catch(e){console.warn('Init:',e);}
  const ov=document.getElementById('lov');
  ov.classList.add('hidden');setTimeout(()=>ov.remove(),500);
}

async function refreshStats(){
  try{const s=await api('GET','/api/stats');S.statTotal=s.total;S.statUntagged=s.untagged;refreshStats_ui();}catch(e){}
}
function refreshStats_ui(){
  document.getElementById('pill-total').innerHTML=t('stat-total',{n:`<b id="stat-total">${S.statTotal}</b>`});
  document.getElementById('pill-untagged').innerHTML=t('stat-untagged',{n:`<b id="stat-untagged">${S.statUntagged}</b>`});
}
function updateStats(total,untagged){S.statTotal=total;S.statUntagged=untagged;refreshStats_ui();}

// ── Scan ──────────────────────────────────────────────────────────────────────
async function scanFolder(){
  const folder=document.getElementById('folder-input').value.trim();
  if(!folder)return toast(t('err-no-folder'));
  S.folder=folder;
  try{const res=await api('POST','/api/scan',{folder});
    toast(t('scan-done',{total:res.total,new:res.new,untagged:res.untagged}));
    updateStats(res.total,res.untagged);refreshGallery();loadTagCategories();
  }catch(e){toast('❌ '+e.message);}
}

// ── Tagging ───────────────────────────────────────────────────────────────────
async function startTagging(){
  if(!S.folder)return toast(t('err-scan-first'));
  const threshold=parseFloat(document.getElementById('threshold').value);
  try{await api('POST','/api/tag',{folder:S.folder,threshold,batch_size:8});
    document.getElementById('tag-btn').disabled=true;
    document.getElementById('prog-wrap').classList.add('show');
    S.progressTimer=setInterval(pollProgress,1000);
  }catch(e){toast('❌ '+e.message);}
}
async function pollProgress(){
  try{const p=await api('GET','/api/tag/progress');
    const pct=p.total>0?Math.round(p.done/p.total*100):0;
    document.getElementById('prog-fill').style.width=pct+'%';
    document.getElementById('prog-pct').textContent=pct+'%';
    document.getElementById('prog-cur').textContent=p.current?p.current.slice(-26):`${p.done}/${p.total}`;
    if(!p.running){clearInterval(S.progressTimer);document.getElementById('tag-btn').disabled=false;
      document.getElementById('prog-wrap').classList.remove('show');
      toast(t('tag-done',{n:p.done}));refreshGallery();loadTagCategories();refreshStats();}
  }catch(e){}
}

// ── Tag Categories ────────────────────────────────────────────────────────────
async function loadTagCategories(){
  let url='/api/tags/all';
  if(S.activeCollection===-1) url+='?uncollected=true';
  else if(S.activeCollection!==null) url+=`?collection_id=${S.activeCollection}`;
  const tags=await api('GET',url);
  window._allTags=tags;renderTagCategories(tags);
}
function renderTagCategories(tags){
  const c=document.getElementById('tag-categories');
  if(!tags.length){c.innerHTML=`<div class="s-hint">${t('no-tags')}</div>`;return;}
  const groups={};TAG_CATS.forEach(x=>groups[x.key]=[]);groups['cat-other']=[];
  tags.forEach(item=>{const k=categorizeTag(item.tag);(groups[k]||(groups[k]=[])).push(item);});
  const allCats=[...TAG_CATS.map(x=>x.key),'cat-other'];
  const defOpen=['cat-character','cat-hair','cat-face'];
  c.innerHTML=allCats.map(catKey=>{
    const items=groups[catKey]||[];if(!items.length)return'';
    const isOpen=S.catOpen[catKey]!==undefined?S.catOpen[catKey]:defOpen.includes(catKey);
    return`<div class="cat-block">
      <div class="cat-header" onclick="toggleCat('${catKey}')">
        <span class="cat-title">${t(catKey)}</span>
        <span class="cat-count">${items.length}</span>
        <span class="cat-arrow ${isOpen?'open':''}" id="arrow-${catKey}">›</span>
      </div>
      <div class="cat-tags ${isOpen?'':'collapsed'}" id="cattags-${catKey}">
        ${items.map(item=>{const zh=getZh(item.tag);
          return`<div class="tag-chip" data-tag="${item.tag}" onclick="clickTagChip(this,'${item.tag.replace(/'/g,"\\'")}')">
            <span class="chip-en">${item.tag}</span>
            ${zh?`<span class="chip-zh">${zh}</span>`:''}
            <span class="chip-n">${item.count}</span>
          </div>`;}).join('')}
      </div>
    </div>`;
  }).join('');
}
function toggleCat(k){
  const el=document.getElementById('cattags-'+k),ar=document.getElementById('arrow-'+k);
  if(!el)return;const o=!el.classList.contains('collapsed');
  el.classList.toggle('collapsed',o);ar.classList.toggle('open',!o);S.catOpen[k]=!o;
}
function collapseAllCats(){
  document.querySelectorAll('.cat-tags').forEach(el=>{
    const k=el.id.replace('cattags-','');
    el.classList.add('collapsed');
    const ar=document.getElementById('arrow-'+k);
    if(ar)ar.classList.remove('open');
    S.catOpen[k]=false;
  });
}
function expandAllCats(){
  document.querySelectorAll('.cat-tags').forEach(el=>{
    const k=el.id.replace('cattags-','');
    el.classList.remove('collapsed');
    const ar=document.getElementById('arrow-'+k);
    if(ar)ar.classList.add('open');
    S.catOpen[k]=true;
  });
}
function clickTagChip(el,tag){
  document.querySelectorAll(`.tag-chip[data-tag="${tag}"]`).forEach(c=>c.classList.toggle('active'));
  const active=[...new Set([...document.querySelectorAll('.tag-chip.active')].map(c=>c.dataset.tag))];
  document.getElementById('search-input').value=active.join(',');
  S.page=1;refreshGallery();hideSug();
}

// ── Search ────────────────────────────────────────────────────────────────────
const si=document.getElementById('search-input'),sb=document.getElementById('sug-box');
si.addEventListener('input',()=>{
  clearTimeout(window._st);showSug();
  window._st=setTimeout(()=>{S.page=1;refreshGallery();},400);
});
si.addEventListener('keydown',e=>{if(e.key==='Escape')hideSug();});
document.addEventListener('click',e=>{if(!e.target.closest('.search-wrap'))hideSug();});

function getTerms(){return si.value.split(',').map(s=>resolveTag(s)).filter(Boolean);}

function showSug(){
  const parts=si.value.split(','),last=parts[parts.length-1].trim();
  if(!last||!window._allTags){hideSug();return;}
  const ll=last.toLowerCase();
  const m=(window._allTags||[]).filter(item=>{
    const zh=getZh(item.tag);
    return item.tag.includes(ll)||zh.includes(last);
  }).slice(0,8);
  if(!m.length){hideSug();return;}
  sb.innerHTML=m.map(item=>{const zh=getZh(item.tag);
    return`<div class="sug-item" onclick="applySug('${item.tag.replace(/'/g,"\\'")}')">
      <span class="sug-en">${item.tag}</span>
      ${zh?`<span class="sug-zh">${zh}</span>`:''}
      <span class="sug-n">${item.count}</span>
    </div>`;}).join('');
  sb.classList.add('show');
}
function hideSug(){sb.classList.remove('show');}
function applySug(tag){
  const parts=si.value.split(',');parts[parts.length-1]=tag;si.value=parts.join(',');
  hideSug();
  document.querySelectorAll('.tag-chip').forEach(c=>{if(c.dataset.tag===tag)c.classList.add('active');});
  S.page=1;refreshGallery();
}

// ── Gallery ───────────────────────────────────────────────────────────────────
async function refreshGallery(){
  const query=getTerms().join(',');
  const params=new URLSearchParams({query,page:S.page,per_page:S.perPage,untagged_only:S.untaggedOnly});
  if(S.activeCollection===-1) params.set('uncollected','true');
  else if(S.activeCollection!==null) params.set('collection_id',S.activeCollection);
  try{const res=await api('GET',`/api/images?${params}`);
    S.total=res.total;renderGallery(res.images);renderPagination(res.total);
  }catch(e){toast('❌ '+e.message);}
}
function renderGallery(images){
  const el=document.getElementById('gallery');
  if(!images.length){el.innerHTML=`<div class="empty"><div class="empty-icon">🔍</div><div>${t('empty-search')}</div></div>`;return;}
  el.innerHTML=images.map(img=>{
    const sel=S.selected.has(img.id);
    const inTrash=S.trashSet.has(img.id);
    return`<div class="card ${sel?'selected':''} ${inTrash?'dragging':''}"
      data-id="${img.id}"
      draggable="true"
      ondragstart="onCardDragStart(event,${img.id})"
      ondragend="onCardDragEnd(event)"
      onclick="onCardClick(event,${img.id})">
      <div class="card-check">${sel?'✓':''}</div>
      <img class="card-img" src="/api/thumb/${img.id}" loading="lazy" alt="">
      ${!img.tagged?`<div class="ubadge">${t('untagged-filter')}</div>`:''}
      ${inTrash?`<div class="ubadge" style="background:var(--red);left:5px;right:auto">🗑</div>`:''}
      <div class="card-body"><div class="card-tags">
        ${img.tags.slice(0,7).map(tg=>`<span class="mini-tag">${tg}</span>`).join('')}
      </div></div>
    </div>`;}).join('');
  // store last clicked index for shift-select
  window._galleryImages = images;
}
function renderPagination(total){
  const pages=Math.ceil(total/S.perPage)||1;
  document.getElementById('page-info').textContent=t('page-info',{page:S.page,pages,total});
  // jump input
  const ji=document.getElementById('page-jump-input');
  if(ji){ji.max=pages;ji.value=S.page;}

  // build page number buttons
  const btns=document.getElementById('page-btns');
  if(!btns)return;
  const cur=S.page;
  let nums=[];
  // always show first, last, current±2, with ellipsis
  const show=new Set([1,pages]);
  for(let i=Math.max(1,cur-2);i<=Math.min(pages,cur+2);i++)show.add(i);
  const sorted=[...show].sort((a,b)=>a-b);
  let prev=0;
  sorted.forEach(n=>{
    if(n-prev>1)nums.push('...');
    nums.push(n);
    prev=n;
  });

  btns.innerHTML=
    `<button class="page-num-btn" onclick="changePage(-1)" ${cur<=1?'disabled':''}>‹</button>`+
    nums.map(n=>n==='...'
      ?`<span class="page-num-btn ellipsis">…</span>`
      :`<button class="page-num-btn ${n===cur?'active':''}" onclick="goToPage(${n})">${n}</button>`
    ).join('')+
    `<button class="page-num-btn" onclick="changePage(1)" ${cur>=pages?'disabled':''}>›</button>`;
}
function changePage(d){goToPage(S.page+d);}
function goToPage(n){
  const pages=Math.ceil(S.total/S.perPage)||1;
  S.page=Math.max(1,Math.min(pages,n));
  refreshGallery();document.getElementById('gallery').scrollTop=0;
}
function jumpToPage(){
  const v=parseInt(document.getElementById('page-jump-input').value);
  if(!isNaN(v))goToPage(v);
}
document.getElementById('page-jump-input').addEventListener('keydown',e=>{if(e.key==='Enter')jumpToPage();});
function toggleUntagged(){
  S.untaggedOnly=!S.untaggedOnly;
  document.getElementById('untagged-filter').classList.toggle('active',S.untaggedOnly);
  S.page=1;refreshGallery();
}

// ── Collections ───────────────────────────────────────────────────────────────
async function loadCollections(){
  try{
    const res=await api('GET','/api/collections');
    S.collections=res.collections;
    renderCollectionTabs(res.collections,res.uncollected);
    renderAssignSelect(res.collections);
  }catch(e){console.warn('Collections:',e);}
}

function renderCollectionTabs(cols,uncollected){
  const wrap=document.getElementById('col-tabs');
  const all_active=S.activeCollection===null;
  const unc_active=S.activeCollection===-1;
  let html=`<div class="col-tab ${all_active?'active':''}" onclick="switchCollection(null)">
    全部 <span class="tab-count">${S.statTotal||''}</span>
  </div>`;
  cols.forEach(c=>{
    const active=S.activeCollection===c.id;
    html+=`<div class="col-tab ${active?'active':''}" onclick="switchCollection(${c.id})">
      ${c.name} <span class="tab-count">${c.count}</span>
    </div>`;
  });
  html+=`<div class="col-tab ${unc_active?'active':''}" onclick="switchCollection(-1)">
    未分類 <span class="tab-count">${uncollected}</span>
  </div>`;
  html+=`<div class="col-tab-add" onclick="openColModal()" title="管理集合">⊕</div>`;
  wrap.innerHTML=html;
}

function renderAssignSelect(cols){
  const sel=document.getElementById('assign-col-select');
  if(!sel)return;
  sel.innerHTML='<option value="">移入集合...</option>'+
    cols.map(c=>`<option value="${c.id}">${c.name}</option>`).join('')+
    '<option value="-1">移出集合（未分類）</option>';
}

function switchCollection(id){
  S.activeCollection=id;
  S.page=1;
  S.selected.clear();updateSelCount();
  refreshGallery();loadTagCategories();
  // update tab highlight
  loadCollections();
}

async function bulkAssignCollection(){
  if(!S.selected.size)return toast(t('no-selection'));
  const sel=document.getElementById('assign-col-select');
  if(!sel||!sel.value)return toast('請選擇集合');
  const cid=sel.value==='-1'?null:parseInt(sel.value);
  try{
    const res=await api('POST','/api/images/set-collection',{
      image_ids:[...S.selected],collection_id:cid
    });
    toast(`✅ 已指派 ${res.count} 張圖片`);
    S.selected.clear();updateSelCount();
    loadCollections();refreshGallery();
  }catch(e){toast('❌ '+e.message);}
}

// Collection modal
function openColModal(){
  document.getElementById('col-modal').classList.add('open');
  renderColList();
}
function closeColModal(e){
  if(e&&e.target!==document.getElementById('col-modal'))return;
  document.getElementById('col-modal').classList.remove('open');
}
function renderColList(){
  const list=document.getElementById('col-list');
  list.innerHTML=S.collections.map(c=>`
    <div class="col-list-item">
      <span class="col-list-name">${c.name}</span>
      <span class="col-list-count">${c.count} 張</span>
      <div class="col-list-actions">
        <button class="col-act-btn" onclick="promptRename(${c.id},'${c.name.replace(/'/g,"\'")}')">✎</button>
        <button class="col-act-btn del" onclick="confirmDeleteCol(${c.id},'${c.name.replace(/'/g,"\'")}')">✕</button>
      </div>
    </div>`).join('');
}
async function addCollection(){
  const input=document.getElementById('new-col-input');
  const name=input.value.trim();
  if(!name)return;
  try{
    await api('POST','/api/collections',{name});
    input.value='';
    await loadCollections();
    renderColList();
    toast('✅ 已新增集合：'+name);
  }catch(e){toast('❌ '+e.message);}
}
async function promptRename(id,oldName){
  const name=prompt('重新命名集合：',oldName);
  if(!name||name===oldName)return;
  try{
    await api('PUT','/api/collections',{collection_id:id,name});
    await loadCollections();renderColList();
  }catch(e){toast('❌ '+e.message);}
}
async function confirmDeleteCol(id,name){
  if(!confirm(`刪除集合「${name}」？裡面的圖片會移回未分類。`))return;
  try{
    await api('DELETE',`/api/collections/${id}`);
    if(S.activeCollection===id)S.activeCollection=null;
    await loadCollections();renderColList();
    refreshGallery();
  }catch(e){toast('❌ '+e.message);}
}

// ── Select mode ───────────────────────────────────────────────────────────────
function toggleSelectMode(){
  S.selectMode=!S.selectMode;
  S.selected.clear();
  S.lastClickedIdx=-1;
  document.body.classList.toggle('select-mode',S.selectMode);
  document.getElementById('select-mode-btn').classList.toggle('active',S.selectMode);
  updateSelCount();
  refreshGallery();
}

function onCardClick(e,id){
  if(!S.selectMode){openDetail(id);return;}
  const images=window._galleryImages||[];
  const idx=images.findIndex(img=>img.id===id);
  if(e.shiftKey && S.lastClickedIdx>=0 && idx>=0){
    // range select
    const lo=Math.min(S.lastClickedIdx,idx);
    const hi=Math.max(S.lastClickedIdx,idx);
    for(let i=lo;i<=hi;i++) S.selected.add(images[i].id);
  } else {
    if(S.selected.has(id)) S.selected.delete(id);
    else S.selected.add(id);
    S.lastClickedIdx=idx;
  }
  updateSelCount();
  // update card visuals without full re-render
  document.querySelectorAll('.card').forEach(card=>{
    const cid=parseInt(card.dataset.id);
    const sel=S.selected.has(cid);
    card.classList.toggle('selected',sel);
    const chk=card.querySelector('.card-check');
    if(chk)chk.textContent=sel?'✓':'';
  });
}

function updateSelCount(){
  document.getElementById('sel-count').textContent=S.selected.size;
}

function selectAll(){
  (window._galleryImages||[]).forEach(img=>S.selected.add(img.id));
  updateSelCount();
  document.querySelectorAll('.card').forEach(c=>{
    c.classList.add('selected');
    const chk=c.querySelector('.card-check');
    if(chk)chk.textContent='✓';
  });
}

function clearSelection(){
  S.selected.clear();
  updateSelCount();
  document.querySelectorAll('.card').forEach(c=>{
    c.classList.remove('selected');
    const chk=c.querySelector('.card-check');
    if(chk)chk.textContent='';
  });
}

async function bulkDelete(){
  if(!S.selected.size)return toast(t('no-selection'));
  const n=S.selected.size;
  if(!confirm(`確定要刪除 ${n} 個檔案？此操作無法復原！`))return;
  try{
    const res=await api('POST','/api/images/bulk-delete',{
      image_ids:[...S.selected],delete_files:true
    });
    toast(`✅ 已刪除 ${res.deleted} 個檔案${res.errors.length?'，'+res.errors.length+' 個失敗':''}`);
    S.selected.clear();updateSelCount();
    refreshGallery();loadTagCategories();refreshStats();
  }catch(e){toast('❌ '+e.message);}
}

async function bulkMove(){
  if(!S.selected.size)return toast(t('no-selection'));
  const target=document.getElementById('move-target').value.trim();
  if(!target)return toast('請輸入目標資料夾路徑');
  const n=S.selected.size;
  try{
    const res=await api('POST','/api/images/bulk-move',{
      image_ids:[...S.selected],target_folder:target
    });
    toast(`✅ 已移動 ${res.moved} 個檔案${res.errors.length?'，'+res.errors.length+' 個失敗':''}`);
    S.selected.clear();updateSelCount();
    refreshGallery();
  }catch(e){toast('❌ '+e.message);}
}

// ── Detail ────────────────────────────────────────────────────────────────────
async function openDetail(id){
  const img=await api('GET',`/api/image/${id}`);
  S.detail=img;S.detailTags=[...img.tags];
  _renderDetailUI();
  document.getElementById('det-overlay').classList.add('open');
}

function _renderDetailUI(){
  const img=S.detail;
  const images=window._galleryImages||[];
  const idx=images.findIndex(i=>i.id===img.id);
  S.detailIdx=idx;

  document.getElementById('det-img').src=`/api/full/${img.id}`;
  document.getElementById('det-path').textContent=img.path;
  document.querySelector('.reveal-btn').title=t('reveal-tip');

  // Nav arrows
  const prevBtn=document.getElementById('det-prev');
  const nextBtn=document.getElementById('det-next');
  const info=document.getElementById('det-nav-info');
  if(idx>=0){
    prevBtn.disabled=idx<=0;
    nextBtn.disabled=idx>=images.length-1;
    info.textContent=`${idx+1} / ${images.length}`;
  } else {
    prevBtn.disabled=true;nextBtn.disabled=true;info.textContent='';
  }
  renderDetTags();
}

async function navDetail(dir){
  const images=window._galleryImages||[];
  const newIdx=(S.detailIdx||0)+dir;
  if(newIdx<0||newIdx>=images.length)return;
  const img=images[newIdx];
  const full=await api('GET',`/api/image/${img.id}`);
  S.detail=full;S.detailTags=[...full.tags];
  _renderDetailUI();
}

// Keyboard navigation
document.addEventListener('keydown',e=>{
  const overlay=document.getElementById('det-overlay');
  if(!overlay.classList.contains('open'))return;
  if(e.target.tagName==='INPUT')return;
  if(e.key==='ArrowLeft'||e.key==='ArrowUp'){e.preventDefault();navDetail(-1);}
  else if(e.key==='ArrowRight'||e.key==='ArrowDown'){e.preventDefault();navDetail(1);}
  else if(e.key==='Escape'){closeDetail();}
});

function renderDetTags(){
  document.getElementById('det-tags').innerHTML=S.detailTags.map((tg,i)=>{
    const zh=getZh(tg);
    return`<div class="edit-tag">
      <span class="edit-tag-en">${tg}</span>
      ${zh?`<span class="edit-tag-zh">${zh}</span>`:''}
      <span class="del" onclick="removeTag(${i})">×</span>
    </div>`;}).join('');
}
function removeTag(i){S.detailTags.splice(i,1);renderDetTags();}
function addTag(){
  const input=document.getElementById('new-tag-input');
  const val=resolveTag(input.value).toLowerCase().replace(/\s+/g,' ');
  if(!val)return;
  if(!S.detailTags.includes(val)){S.detailTags.push(val);renderDetTags();}
  input.value='';
}
document.getElementById('new-tag-input').addEventListener('keydown',e=>{if(e.key==='Enter')addTag();});

async function saveTags(){
  if(!S.detail)return;
  await api('PUT','/api/image/tags',{image_id:S.detail.id,tags:S.detailTags});
  toast(t('saved'));
  // Stay on current image, just refresh gallery in background
  refreshGallery();loadTagCategories();
}
async function deleteImagePermanent(){
  if(!S.detail)return;
  if(!confirm('永久刪除此檔案？此操作無法復原！'))return;
  const images=window._galleryImages||[];
  const idx=S.detailIdx||0;
  try{
    await api('POST','/api/images/bulk-delete',{image_ids:[S.detail.id],delete_files:true});
    toast('✅ 已永久刪除');
    // Try to open next image, otherwise close
    const remaining=images.filter(i=>i.id!==S.detail.id);
    window._galleryImages=remaining;
    if(remaining.length===0){closeDetail();refreshGallery();return;}
    const nextIdx=Math.min(idx,remaining.length-1);
    const nextImg=await api('GET',`/api/image/${remaining[nextIdx].id}`);
    S.detail=nextImg;S.detailTags=[...nextImg.tags];
    _renderDetailUI();
    refreshGallery();refreshStats();
  }catch(e){toast('❌ '+e.message);}
}
async function revealInExplorer(){
  if(!S.detail)return;
  try{await api('GET',`/api/reveal/${S.detail.id}`);}
  catch(e){toast('❌ '+e.message);}
}
function closeDetail(e){
  if(e&&e.target!==document.getElementById('det-overlay'))return;
  document.getElementById('det-overlay').classList.remove('open');S.detail=null;
}




// ── Trash Bin ─────────────────────────────────────────────────────────────────
let _dragImgId = null;

function onCardDragStart(e, id){
  _dragImgId = id;
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain', String(id));
  setTimeout(()=>e.target.classList.add('dragging'), 0);
}
function onCardDragEnd(e){
  e.target.classList.remove('dragging');
  _dragImgId = null;
}
function onTrashDragOver(e){
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  document.getElementById('trash-fab').classList.add('drag-over');
}
function onTrashDragLeave(e){
  document.getElementById('trash-fab').classList.remove('drag-over');
}
function onTrashDrop(e){
  e.preventDefault();
  document.getElementById('trash-fab').classList.remove('drag-over');
  const id = parseInt(e.dataTransfer.getData('text/plain'));
  if(!id||isNaN(id)) return;
  addToTrash(id);
}

async function addToTrash(id){
  if(S.trashSet.has(id)) return;
  S.trashSet.add(id);
  // Fetch image info if not cached
  if(!S.trashItems[id]){
    try{
      const img = await api('GET', `/api/image/${id}`);
      S.trashItems[id] = img;
    }catch(e){ S.trashItems[id] = {id, path:'unknown', tags:[]}; }
  }
  updateTrashFab();
  toast(`🗑 已加入待刪除清單（共 ${S.trashSet.size} 張）`);
  // Re-render gallery to show trash indicator
  renderGallery(window._galleryImages||[]);
}

function updateTrashFab(){
  const fab = document.getElementById('trash-fab');
  const cnt = document.getElementById('trash-count');
  cnt.textContent = S.trashSet.size;
  fab.classList.toggle('has-items', S.trashSet.size > 0);
}

function openTrashPanel(){
  document.getElementById('trash-overlay').classList.add('open');
  renderTrashList();
}
function closeTrashPanel(e){
  if(e && e.target !== document.getElementById('trash-overlay')) return;
  document.getElementById('trash-overlay').classList.remove('open');
}

function renderTrashList(){
  const list = document.getElementById('trash-list');
  if(!S.trashSet.size){
    list.innerHTML = `<div class="trash-empty">
      <div class="trash-empty-icon">🗑</div>
      <div>清單為空</div>
      <div style="font-size:11px;margin-top:4px">將圖片拖曳到右下角垃圾桶加入</div>
    </div>`;
    return;
  }
  list.innerHTML = [...S.trashSet].map(id=>{
    const img = S.trashItems[id] || {id, path:'loading...', tags:[]};
    const name = img.path.split(/[\/]/).pop();
    const tags = img.tags.slice(0,5).join(', ');
    return`<div class="trash-item">
      <img class="trash-item-thumb" src="/api/thumb/${id}" alt="">
      <div class="trash-item-info">
        <div class="trash-item-name" title="${img.path}">${name}</div>
        <div class="trash-item-tags">${tags||'無 tag'}</div>
      </div>
      <button class="trash-item-remove" onclick="removeFromTrash(${id})" title="從清單移除">✕</button>
    </div>`;
  }).join('');
}

function removeFromTrash(id){
  S.trashSet.delete(id);
  delete S.trashItems[id];
  updateTrashFab();
  renderTrashList();
  renderGallery(window._galleryImages||[]);
}

function clearTrash(){
  S.trashSet.clear();
  S.trashItems = {};
  updateTrashFab();
  renderTrashList();
  renderGallery(window._galleryImages||[]);
}

async function confirmDeleteAll(){
  if(!S.trashSet.size) return;
  const n = S.trashSet.size;
  if(!confirm(`永久刪除這 ${n} 個檔案？此操作無法復原！`)) return;
  try{
    const ids = [...S.trashSet];
    const res = await api('POST', '/api/images/bulk-delete', {image_ids: ids, delete_files: true});
    toast(`✅ 已永久刪除 ${res.deleted} 個檔案`);
    clearTrash();
    closeTrashPanel();
    refreshGallery();
    refreshStats();
    loadTagCategories();
  }catch(e){ toast('❌ '+e.message); }
}
// ── Scan History ──────────────────────────────────────────────────────────────
async function openHistoryModal(){
  document.getElementById('history-overlay').classList.add('open');
  await renderHistoryList();
}
function closeHistoryModal(e){
  if(e&&e.target!==document.getElementById('history-overlay'))return;
  document.getElementById('history-overlay').classList.remove('open');
}
async function renderHistoryList(){
  const list=document.getElementById('history-list');
  try{
    const history=await api('GET','/api/scan-history');
    if(!history.length){
      list.innerHTML='<div class="history-empty">尚無匯入紀錄<br>掃描資料夾後會自動記錄</div>';
      return;
    }
    list.innerHTML=history.map(h=>`
      <div class="history-item">
        <div class="history-item-main">
          <div class="history-folder">${h.folder}</div>
          <div class="history-meta">
            <span class="history-badge">📁 <b>${h.image_count.toLocaleString()}</b> 張圖片</span>
            <span class="history-badge">🔄 掃描 <b>${h.scan_count}</b> 次</span>
            <span class="history-badge">🕐 最後：${h.last_scan}</span>
          </div>
        </div>
        <div class="history-actions">
          <button class="h-btn" onclick="loadFolderFromHistory(this.dataset.folder)" data-folder="${h.folder}" title="重新載入此資料夾">↺</button>
          <button class="h-btn del" onclick="deleteHistory(this.dataset.folder)" data-folder="${h.folder}" title="刪除此紀錄">✕</button>
        </div>
      </div>`).join('');
  }catch(e){
    list.innerHTML='<div class="history-empty">載入失敗</div>';
  }
}
async function loadFolderFromHistory(folder){
  document.getElementById('folder-input').value=folder;
  S.folder=folder;
  closeHistoryModal();
  await scanFolder();
}
async function deleteHistory(folder){
  if(!confirm('刪除此匯入紀錄？（不影響已匯入的圖片資料）'))return;
  try{
    await api('DELETE','/api/scan-history',{folder});
    await renderHistoryList();
    toast('✅ 已刪除紀錄');
  }catch(e){toast('❌ '+e.message);}
}
// ── Analytics ─────────────────────────────────────────────────────────────────
const CAT_COLORS = {
  'cat-character': '#7c6aff',
  'cat-hair':      '#a78bfa',
  'cat-face':      '#f472b6',
  'cat-clothing':  '#fb923c',
  'cat-pose':      '#34d399',
  'cat-background':'#38bdf8',
  'cat-style':     '#fbbf24',
  'cat-other':     '#94a3b8',
};
const CAT_LABELS_ZH = {
  'cat-character':'人物','cat-hair':'髮型髮色','cat-face':'五官表情',
  'cat-clothing':'服裝配飾','cat-pose':'姿勢構圖','cat-background':'場景背景',
  'cat-style':'畫風品質','cat-other':'其他',
};

let analyticsSelTags = new Set();
let analyticsActiveCat = null;

async function openAnalytics(){
  document.getElementById('analytics-overlay').classList.add('open');
  await renderAnalyticsChart();
}
function closeAnalytics(e){
  if(e&&e.target!==document.getElementById('analytics-overlay'))return;
  document.getElementById('analytics-overlay').classList.remove('open');
}

async function renderAnalyticsChart(){
  const area = document.getElementById('chart-area');
  area.innerHTML = '<div style="color:var(--text3);font-size:13px">載入中...</div>';

  let url = '/api/tags/all';
  if(S.activeCollection===-1) url+='?uncollected=true';
  else if(S.activeCollection!==null) url+=`?collection_id=${S.activeCollection}`;
  const allTags = await api('GET', url);
  if(!allTags.length){ area.innerHTML='<div style="color:var(--text3)">尚無 tag 資料</div>'; return; }

  // Group by category
  const groups = {};
  Object.keys(CAT_COLORS).forEach(k=>groups[k]=[]);
  allTags.forEach(item=>{
    const cat = categorizeTag(item.tag);
    (groups[cat]||(groups[cat]=[])).push(item);
  });

  const W=560, H=560, cx=W/2, cy=H/2;
  const inner=90, outer=200, outerHover=210;
  const cats = Object.keys(CAT_COLORS).filter(k=>(groups[k]||[]).length>0);
  const totalCount = cats.reduce((s,k)=>s+(groups[k]||[]).reduce((ss,t)=>ss+t.count,0),0);

  // Build arc data
  let startAngle = -Math.PI/2;
  const arcs = cats.map(cat=>{
    const items = groups[cat]||[];
    const catTotal = items.reduce((s,t)=>s+t.count,0);
    const angle = (catTotal/totalCount)*2*Math.PI;
    const arc = {cat, items, catTotal, startAngle, endAngle: startAngle+angle};
    startAngle += angle;
    return arc;
  });

  function polar(r, a){ return [cx+r*Math.cos(a), cy+r*Math.sin(a)]; }
  function arcPath(r1,r2,a1,a2){
    const [x1,y1]=polar(r1,a1),[x2,y2]=polar(r2,a1);
    const [x3,y3]=polar(r2,a2),[x4,y4]=polar(r1,a2);
    const lg=(a2-a1>Math.PI)?1:0;
    return `M${x1},${y1} L${x2},${y2} A${r2},${r2},0,${lg},1,${x3},${y3} L${x4},${y4} A${r1},${r1},0,${lg},0,${x1},${y1} Z`;
  }

  // Inner donut segments (cat totals) + outer tick bars
  let svgParts = `<svg viewBox="0 0 ${W} ${H}" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;max-height:520px">`;
  svgParts += `<defs><filter id="glow"><feGaussianBlur stdDeviation="3" result="coloredBlur"/><feMerge><feMergeNode in="coloredBlur"/><feMergeNode in="SourceGraphic"/></feMerge></filter></defs>`;

  // Background circle
  svgParts += `<circle cx="${cx}" cy="${cy}" r="${inner-2}" fill="var(--surface2)" opacity="0.6"/>`;

  arcs.forEach(arc=>{
    const mid=(arc.startAngle+arc.endAngle)/2;
    const color=CAT_COLORS[arc.cat];
    const isActive=analyticsActiveCat===arc.cat;

    // Main donut segment
    svgParts += `<path d="${arcPath(inner,outer,arc.startAngle+0.015,arc.endAngle-0.015)}"
      fill="${color}" opacity="${isActive?1:0.7}" stroke="var(--surface)" stroke-width="2"
      style="cursor:pointer;transition:all 0.2s"
      onmouseenter="showChartTooltip(event,'${CAT_LABELS_ZH[arc.cat]}','${arc.items.length} 種 tag，共 ${arc.catTotal.toLocaleString()} 次')"
      onmouseleave="hideChartTooltip()"
      onclick="selectAnalyticsCat('${arc.cat}')"
    />`;

    // Outer bar segments for top tags
    const topTags = [...arc.items].sort((a,b)=>b.count-a.count).slice(0,12);
    const maxCount = topTags[0]?.count||1;
    const barSpan = (arc.endAngle-arc.startAngle)*0.85;
    const barGap = barSpan/Math.max(topTags.length,1);
    topTags.forEach((tag,i)=>{
      const barLen = 60*(tag.count/maxCount)+10;
      const a1 = arc.startAngle + (arc.endAngle-arc.startAngle)*0.075 + i*barGap;
      const a2 = a1+barGap*0.75;
      svgParts += `<path d="${arcPath(outer+6, outer+6+barLen, a1, a2)}"
        fill="${color}" opacity="0.5" style="cursor:pointer"
        onmouseenter="showChartTooltip(event,'${tag.tag.replace(/'/g,"\'")}','${tag.count.toLocaleString()} 張')"
        onmouseleave="hideChartTooltip()"
        onclick="selectAnalyticsCat('${arc.cat}')"
      />`;
    });

    // Label
    const labelR = outer+75;
    const [lx,ly] = polar(labelR, mid);
    const anchor = Math.cos(mid)>0.1?'start':Math.cos(mid)<-0.1?'end':'middle';
    svgParts += `<text x="${lx}" y="${ly}" text-anchor="${anchor}" dominant-baseline="middle"
      font-size="11" font-family="Inter,sans-serif" fill="${isActive?color:'var(--text2)'}"
      font-weight="${isActive?600:400}" style="cursor:pointer;pointer-events:none">
      ${CAT_LABELS_ZH[arc.cat]}
    </text>`;

    // Count badge
    const badgeR = (inner+outer)/2;
    const [bx,by] = polar(badgeR, mid);
    svgParts += `<text x="${bx}" y="${by}" text-anchor="middle" dominant-baseline="middle"
      font-size="9" font-family="JetBrains Mono,monospace" fill="rgba(255,255,255,0.8)"
      style="pointer-events:none">${arc.items.length}</text>`;
  });

  // Center text
  svgParts += `<text x="${cx}" y="${cy-10}" text-anchor="middle" font-size="22" font-weight="700"
    font-family="Inter,sans-serif" fill="var(--text)">${allTags.length}</text>`;
  svgParts += `<text x="${cx}" y="${cy+12}" text-anchor="middle" font-size="11"
    font-family="Inter,sans-serif" fill="var(--text3)">種 Tags</text>`;

  svgParts += '</svg>';
  area.innerHTML = svgParts;

  // If a cat is already active, re-render its list
  if(analyticsActiveCat) renderTagDetailList(groups[analyticsActiveCat]||[], analyticsActiveCat);
  renderAnalyticsSelTags();
}

function selectAnalyticsCat(cat){
  analyticsActiveCat = cat;
  const allTagsData = window._allTags||[];
  const groups={};
  Object.keys(CAT_COLORS).forEach(k=>groups[k]=[]);
  allTagsData.forEach(item=>{
    const c=categorizeTag(item.tag);
    (groups[c]||(groups[c]=[])).push(item);
  });
  renderTagDetailList(groups[cat]||[], cat);
  renderAnalyticsChart(); // re-render to highlight active
}

function renderTagDetailList(items, cat){
  const sorted=[...items].sort((a,b)=>b.count-a.count);
  const maxCount=sorted[0]?.count||1;
  const color=CAT_COLORS[cat];
  document.getElementById('detail-cat-title').textContent=CAT_LABELS_ZH[cat]||cat;
  document.getElementById('detail-cat-sub').textContent=`${sorted.length} 種 tag`;
  document.getElementById('tag-detail-list').innerHTML=sorted.map(item=>{
    const zh=getZh(item.tag);
    const barW=Math.max(4,Math.round(80*(item.count/maxCount)));
    const sel=analyticsSelTags.has(item.tag);
    return`<div class="tag-item ${sel?'selected':''}" onclick="toggleAnalyticsTag('${item.tag.replace(/'/g,"\'")}')">
      <div class="tag-item-bar" style="width:${barW}px;background:${color}"></div>
      <span class="tag-item-name">${item.tag}</span>
      ${zh?`<span class="tag-item-zh">${zh}</span>`:''}
      <span class="tag-item-count">${item.count}</span>
    </div>`;
  }).join('');
}

function toggleAnalyticsTag(tag){
  if(analyticsSelTags.has(tag)) analyticsSelTags.delete(tag);
  else analyticsSelTags.add(tag);
  renderAnalyticsSelTags();
  // update list highlight
  document.querySelectorAll('.tag-item').forEach(el=>{
    const name=el.querySelector('.tag-item-name')?.textContent;
    if(name) el.classList.toggle('selected', analyticsSelTags.has(name));
  });
}

function renderAnalyticsSelTags(){
  const wrap=document.getElementById('sel-tags-wrap');
  const hint=document.getElementById('sel-tags-hint');
  if(!analyticsSelTags.size){
    if(hint)hint.style.display='';
    wrap.innerHTML='<span id="sel-tags-hint">點擊 tag 加入搜索...</span>';
    return;
  }
  wrap.innerHTML=[...analyticsSelTags].map(tag=>`
    <div class="sel-tag-chip">
      ${tag}
      <span class="x" onclick="event.stopPropagation();toggleAnalyticsTag('${tag.replace(/'/g,"\'")}')">×</span>
    </div>`).join('');
}

function clearAnalyticsSel(){
  analyticsSelTags.clear();
  renderAnalyticsSelTags();
  document.querySelectorAll('.tag-item').forEach(el=>el.classList.remove('selected'));
}

function applyAnalyticsSearch(){
  if(!analyticsSelTags.size) return;
  const terms=[...analyticsSelTags].join(',');
  document.getElementById('search-input').value=terms;
  closeAnalytics();
  S.page=1;
  refreshGallery();
}

function showChartTooltip(e, title, sub){
  const tt=document.getElementById('chart-tooltip');
  tt.innerHTML=`<b>${title}</b><br><span style="color:var(--text3)">${sub}</span>`;
  tt.style.display='block';
  tt.style.left=(e.clientX+14)+'px';
  tt.style.top=(e.clientY-10)+'px';
}
function hideChartTooltip(){
  document.getElementById('chart-tooltip').style.display='none';
}

function toast(msg){
  const el=document.createElement('div');el.className='toast';el.textContent=msg;
  document.body.appendChild(el);setTimeout(()=>el.remove(),3500);
}

init();
</script>
</body>
</html>
